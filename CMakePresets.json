{
  "version": 3,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Windows Development",
      "inherits": "windows-debug-vcpkg"
    },
    {
      "name": "windows-debug-vcpkg",
      "displayName": "Windows Debug (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-debug-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "environment": {
        "VSLANG": "1033"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_PREFIX_PATH": "${sourceDir}/deps/qt/6.7.3/msvc2019_64",
        "Qt6_DIR": "${sourceDir}/deps/qt/6.7.3/msvc2019_64/lib/cmake/Qt6",
        "VCPKG_QT": "OFF",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-release-vcpkg",
      "displayName": "Windows Release (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-release-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "environment": {
        "VSLANG": "1033"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_PREFIX_PATH": "${sourceDir}/deps/qt/6.7.3/msvc2019_64",
        "Qt6_DIR": "${sourceDir}/deps/qt/6.7.3/msvc2019_64/lib/cmake/Qt6",
        "VCPKG_QT": "OFF",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "BUILD_INSTALLER": "ON"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "$penv{HOMEBREW_PREFIX}/opt/qtbase;$penv{HOMEBREW_PREFIX}/opt/qttools;$penv{HOMEBREW_PREFIX}/opt/qtsvg;$penv{HOMEBREW_PREFIX}/opt/qtwebengine;$penv{HOMEBREW_PREFIX}/opt/qtvirtualkeyboard;$penv{HOMEBREW_PREFIX}/opt/qtdeclarative;$penv{HOMEBREW_PREFIX}/opt/openssl@3",
        "QT_ADDITIONAL_PACKAGES_PREFIX_PATH": "$penv{HOMEBREW_PREFIX}/opt/qttools",
        "BUILD_DEV_DOCS": "OFF",
        "BUILD_TESTS": "OFF",
        "BUILD_USER_DOCS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "displayName": "Build Windows development binaries",
      "configurePreset": "dev",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow",
        "deskflow-core",
        "deskflow-daemon"
      ]
    },
    {
      "name": "gui",
      "displayName": "Build Windows Deskflow GUI for development",
      "configurePreset": "dev",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow"
      ]
    },
    {
      "name": "core",
      "displayName": "Build Windows deskflow-core for development",
      "configurePreset": "dev",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow-core"
      ]
    },
    {
      "name": "daemon",
      "displayName": "Build Windows deskflow-daemon for development",
      "configurePreset": "dev",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow-daemon"
      ]
    },
    {
      "name": "platform",
      "displayName": "Build Windows platform library for development",
      "configurePreset": "dev",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "platform"
      ]
    },
    {
      "name": "windows-debug-vcpkg",
      "displayName": "Build Windows Debug (vcpkg)",
      "configurePreset": "windows-debug-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-debug-vcpkg-core",
      "displayName": "Build deskflow-core for Windows Debug (vcpkg)",
      "configurePreset": "windows-debug-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow-core"
      ]
    },
    {
      "name": "windows-debug-vcpkg-gui",
      "displayName": "Build Deskflow GUI for Windows Debug (vcpkg)",
      "configurePreset": "windows-debug-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow"
      ]
    },
    {
      "name": "windows-debug-vcpkg-daemon",
      "displayName": "Build deskflow-daemon for Windows Debug (vcpkg)",
      "configurePreset": "windows-debug-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow-daemon"
      ]
    },
    {
      "name": "windows-debug-vcpkg-platform",
      "displayName": "Build platform library for Windows Debug (vcpkg)",
      "configurePreset": "windows-debug-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "platform"
      ]
    },
    {
      "name": "windows-release-vcpkg",
      "displayName": "Build Windows Release (vcpkg)",
      "configurePreset": "windows-release-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-release-vcpkg-msi",
      "displayName": "Build Windows Release MSI inputs",
      "configurePreset": "windows-release-vcpkg",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "targets": [
        "deskflow",
        "deskflow-core",
        "deskflow-daemon",
        "wix-custom"
      ]
    },
    {
      "name": "macos-release",
      "displayName": "Build macOS Release",
      "configurePreset": "macos-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-release-gui",
      "displayName": "Build macOS Deskflow GUI",
      "configurePreset": "macos-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "targets": [
        "Deskflow"
      ]
    },
    {
      "name": "macos-release-core",
      "displayName": "Build macOS deskflow-core",
      "configurePreset": "macos-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "targets": [
        "deskflow-core"
      ]
    },
    {
      "name": "macos-release-platform",
      "displayName": "Build macOS platform library",
      "configurePreset": "macos-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "targets": [
        "platform"
      ]
    },
    {
      "name": "macos-install-app",
      "displayName": "Install macOS app bundle",
      "configurePreset": "macos-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "targets": [
        "install-macos-app"
      ]
    },
    {
      "name": "macos-install-app-fast",
      "displayName": "Fast install macOS app bundle",
      "configurePreset": "macos-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "targets": [
        "install-macos-app-fast"
      ]
    }
  ]
}
